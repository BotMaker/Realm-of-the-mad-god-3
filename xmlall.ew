global function object_type_from_name(sequence name)
  for i=1 to length(object_list) do
    if sequence(object_delta(i,object_idd)) then
      if equal(lower(object_delta(i,object_idd)),lower(name)) then
        return i
      end if
    end if
  end for
  if length(name)>0 then
    puts(1,"not found "&name&"\n")
  end if
  return -1
end function




--============================ new code for creating source code==================================================--

sequence terrain_type
terrain_type = {}

function find_terrain_type(sequence terrain)
    for i = 1 to length(terrain_type) do
        if equal(terrain, terrain_type[i][1]) then
            return i
        end if
    end for

    return 0
end function


procedure enemys_terrain_build(sequence name, sequence terrain)
    integer ret
    ret = find_terrain_type(terrain)

    if ret = 0 then
        terrain_type = append(terrain_type, {terrain, name})
    else
        if find(name, terrain_type[ret]) = 0 then
            terrain_type[ret] &= {name}
        end if
    end if
end procedure


function safe_const_name(sequence s)
    sequence out
    integer c

    out = ""

    for i = 1 to length(s) do
        c = s[i]

        if c >= 'a' and c <= 'z' then
            out &= c - 32
        elsif (c >= 'A' and c <= 'Z') or (c >= '0' and c <= '9') then
            out &= c
        else
            out &= '_'
        end if
    end for

    while find("__", out) do
        out = out[1..find("__", out)-1] & "_" & out[find("__", out)+2..length(out)]
    end while

    if length(out) > 0 then
        if out[1] >= '0' and out[1] <= '9' then
            out = '_' & out
        end if
    end if

    return out
end function


function find_enemy_object_id(sequence enemy_name)
    for i = 1 to length(object_list) do
        if sequence(object_delta(i, object_enemy)) then
            if equal(object_delta(i, object_idd), enemy_name) then
                return i
            end if
        end if
    end for

    return -1
end function


procedure write_enemy_constants(integer fn)
    integer id
    sequence enemy_name

    puts(fn, "-- enemy object id constants\n")

    for i = 1 to length(terrain_type) do
        for j = 2 to length(terrain_type[i]) do
            enemy_name = terrain_type[i][j]
            id = find_enemy_object_id(enemy_name)
            
            --puts(1,enemy_name&"\n")
            if sequence ( object_projectile_delta(id, 1, object_projectile_lifetime) ) then
              
            
            puts(fn,
                "global constant ENEMY_" &
                safe_const_name(enemy_name) &
                " = " &
                sprint(id) &
                "\n"
            )
            
            end if

            
        end for
    end for

    puts(fn, "\n")
end procedure


procedure write_terrain_lists(integer fn)
    sequence terrain_name
    sequence enemy_name

    puts(fn, "-- terrain enemy lists\n")

    for i = 1 to length(terrain_type) do
        terrain_name = terrain_type[i][1]

        puts(fn,
            "global constant TERRAIN_" &
            safe_const_name(terrain_name) &
            "_ENEMIES = {\n"
        )

        for j = 2 to length(terrain_type[i]) do
            enemy_name = terrain_type[i][j]
            
            --if sequence ( object_projectile_delta(, 1, object_projectile_lifetime) ) then

            puts(fn, "    ENEMY_" & safe_const_name(enemy_name))
            if j < length(terrain_type[i]) then
                puts(fn, ",\n")
            else
                puts(fn, "\n")
            end if
            
            --end if
        end for

        puts(fn, "}\n\n")
    end for
end procedure


procedure write_terrain_name_constants(integer fn)
    puts(fn, "-- terrain constants\n")

    for i = 1 to length(terrain_type) do
        puts(fn,
            "global constant TERRAIN_" &
            safe_const_name(terrain_type[i][1]) &
            " = \"" &
            terrain_type[i][1] &
            "\"\n"
        )
    end for

    puts(fn, "\n")
end procedure


procedure write_terrain_table(integer fn)
    puts(fn, "-- terrain lookup table\n")
    puts(fn, "global constant TERRAIN_ENEMY_TABLE = {\n")

    for i = 1 to length(terrain_type) do
        puts(fn,
            "    {TERRAIN_" &
            safe_const_name(terrain_type[i][1]) &
            ", TERRAIN_" &
            safe_const_name(terrain_type[i][1]) &
            "_ENEMIES}"
        )

        if i < length(terrain_type) then
            puts(fn, ",\n")
        else
            puts(fn, "\n")
        end if
    end for

    puts(fn, "}\n\n")
end procedure


procedure find_all_enemys()
    integer fn

    terrain_type = {}

    for i = 1 to length(object_list) do
    
      if sequence(object_delta(i, object_enemy)) then
    if sequence(object_projectile_delta(i, 1, object_projectile_lifetime)) then
      if sequence (object_delta(i, object_idd) ) then
            if sequence(object_delta(i, object_terrain)) then
                enemys_terrain_build(
                    object_delta(i, object_idd),
                    object_delta(i, object_terrain)
                )
            else
                enemys_terrain_build(
                    object_delta(i, object_idd),
                    "none"
                )
            end if
       end if
       end if
      end if
    end for

    fn = open("terrain_enemy_data.ew", "w")

    puts(fn, "-- auto generated enemy terrain file\n\n")

    write_terrain_name_constants(fn)
    write_enemy_constants(fn)
    write_terrain_lists(fn)
    write_terrain_table(fn)

    close(fn)
end procedure

--find_all_enemys()


