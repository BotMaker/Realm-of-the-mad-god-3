global function object_delta( integer index, integer id )
  
  if length(object_list[ index ])=0 then
  	return -2
  end if
  if integer(object_list[ index ][id][2]) then
  	return -1
  end if	

  --if length(object_list[ index ][id][2])=0 then
  --	return -1
  --else
    return object_list[ index ][id][2]
  --end if

end function


global function object_delta_mod( integer index, integer id )
  
    if length(object_list[ index ]) then
      return object_list[ index ][id][2]
    end if
    return 0
end function


global function object_projectile_delta( integer index, integer bullettype ,integer id )
  if length(object_list[ index ]) =0 then
     --puts(1,"not found object_projectile_delta "&sprint(index)&"\n")
     return -1
  else
    --puts(1,"found object_projectile_delta "&sprint(index)&"\n")
  end if
  if length(object_list[ index ][object_projectile])=0 then
    return -3
  end if
  
  if integer(object_list[ index ][object_projectile][bullettype][id][2]) then
    return -2
  end if

  return object_list[ index ][object_projectile][bullettype][id][2]
end function


procedure object_bulletid_settype_backup()
integer id
  for i=1 to length(object_list) do
    if length(object_list[i]) then
    if length(object_list[ i][object_projectile]) then
    if sequence(object_projectile_delta(i,1,object_projectile_ObjectId)) then
     
     id= projectile_type_from_name(object_projectile_delta(i,1,object_projectile_ObjectId))
     object_list[ i ][object_projectile][1][object_projectile_ObjectId][2]=sprint(id)
     
    end if
    end if
    end if
  end for
 
end procedure
--object_bulletid_settype()


procedure object_bulletid_settype()
    integer pcount
    sequence id
    object rawid

    for i = 1 to length(object_list) do
        if length(object_list[i]) then

            if sequence(object_list[i][object_projectile]) then
                pcount = length(object_list[i][object_projectile])

                for p = 1 to pcount do
                    if sequence(object_list[i][object_projectile][p]) then
                        rawid = object_list[i][object_projectile][p][object_projectile_ObjectId][2]

                        if sequence(rawid) and length(rawid) > 0 then
                            id = sprint(projectile_type_from_name(rawid))

                            if length(id) > 0 then
                                object_list[i][object_projectile][p][object_projectile_ObjectId][2] = id
                            else
                                puts(1, "failed projectile lookup: object=" 
                                    & object_delta(i, object_idd) 
                                    & " projectile=" & sprint(p) 
                                    & " objectid=" & rawid & "\n")
                            end if
                        end if
                    end if
                end for
            end if

        end if
    end for
end procedure
object_bulletid_settype()

